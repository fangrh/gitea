{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content repository gds-viewer">
	{{template "repo/header" .}}
	<iframe
		src="http://localhost:8000/viewer?repo={{.Repository.FullName}}&branch={{.BranchName}}"
		style="width:100%; flex-grow:1; border:none; min-height:600px;"
		allow="fullscreen"
		sandbox="allow-scripts allow-same-origin allow-clipboard-write"
		title="GDS Viewer"
	></iframe>
</div>
<style>.gds-viewer { display:flex; flex-direction:column; height:calc(100vh - 100px); } .gds-viewer iframe { flex-grow:1; }</style>
{{template "base/footer" .}}
